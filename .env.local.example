# Neon Postgres connection string
# Get this from https://console.neon.tech (Connection Details > "Pooled" URL works well)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Password for the /admin area
ADMIN_PASSWORD=change-me

# Secret used to sign the admin session cookie (any long random string)
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
